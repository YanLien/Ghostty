# ============================================================
# Ghostty config — generated by Claude (2026/06/27)
# IMPORTANT: Ghostty does NOT strip inline comments.
#   `key = value # foo` makes "# foo" part of the value and
#   silently breaks that line. Keep ALL comments on their own line.
# Reload inside Ghostty with Cmd+Shift+,
# ============================================================

# ---------- Font ----------
# Verified installed locally; CJK uses system auto-fallback
font-family = ComicShannsMono Nerd Font Mono
# CJK fallback: PingFang SC (Apple's system Chinese font) for cleaner Chinese glyphs
font-family = PingFang SC
font-size = 16
# Programming ligatures (ignored if the font lacks the feature)
font-feature = calt
font-feature = liga

# ---------- Theme & background ----------
# Fixed light. Alternatives: TokyoNight Day / Atom One Light / Gruvbox Light
theme = Apple System Colors Light
# Solid opaque background (Ghostty default — no opacity/blur needed)

# ---------- Cursor ----------
cursor-style = block
cursor-style-blink = false
# Thicker bar cursor (the thin line in shell insert mode); +50% wider
adjust-cursor-thickness = +50%
# Black cursor — maximum contrast on light background
cursor-color = #000000
# Enable ssh-terminfo: Ghostty auto-pushes xterm-ghostty terminfo to remotes over SSH.
shell-integration-features = cursor,sudo,title,ssh-terminfo

# ---------- Window appearance ----------
window-theme = light
window-padding-x = 10
# top/bottom: more on top, less on bottom (avoid crowding the tab bar)
window-padding-y = 8,4
window-padding-balance = true
window-decoration = true
macos-titlebar-style = transparent
window-save-state = always
window-colorspace = display-p3

# ---------- macOS behavior ----------
# Option acts as Alt — handy for tmux, emacs Meta, zsh Alt-. etc.
macos-option-as-alt = true

# ---------- macOS icon ----------
# ⚠️ Known bug in Ghostty 1.3.x (github #11561) may cause this NOT to apply.
# Valid styles: official/blueprint/chalkboard/microchip/glass/holographic/paper/retro/xray/custom-style
macos-icon = retro
# Icon frame material: aluminum (default) / beige
macos-icon-frame = aluminum

# ---------- Scrolling & mouse ----------
scrollback-limit = 100000
mouse-scroll-multiplier = 3
mouse-hide-while-typing = true

# ---------- Tabs ----------
# New tabs open on the right
window-new-tab-position = end

# ---------- Dim unfocused splits to emphasize focus ----------
unfocused-split-opacity = 0.85
unfocused-split-fill = #e6e9ef

# ---------- Clipboard ----------
# Auto-copy selection to clipboard; trim trailing spaces; warn on risky pastes
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true

# ---------- Font rendering ----------
# Disable glyph thickening (caused blurry text with this font)
font-thicken = false
# Bold text uses normal-brightness colors (keeps the palette clean)
bold-is-bright = false

# ---------- Window overlay ----------
# Show a size hint while resizing (only after the first resize)
resize-overlay = after-first

# ---------- Keybindings ----------
# Split panes: Cmd+D = vertical (right), Cmd+Shift+D = horizontal (down)
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down
