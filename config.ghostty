# ============================================================
# Ghostty config — generated by Claude (2026/06/27)
# Edits apply on save; or reload inside Ghostty with Cmd+Shift+,
# ============================================================

# ---------- Font ----------
# Verified installed locally; CJK uses system auto-fallback
font-family = ComicShannsMono Nerd Font Mono
font-size = 14
font-feature = calt     # programming ligatures (ignored if unsupported)
font-feature = liga

# ---------- Theme & background ----------
theme = Catppuccin Latte          # fixed light; swap e.g. TokyoNight Day / Atom One Light / Gruvbox Light
background-opacity = 0.90         # translucent, layered over native blur below
background-blur-radius = 20       # macOS native blur (only visible when opacity < 1)

# ---------- Cursor ----------
cursor-style = block
cursor-style-blink = false
shell-integration-features = cursor,sudo,title   # keep these only, avoid altering the prompt

# ---------- Window appearance ----------
window-theme = light
window-padding-x = 10
window-padding-y = 8,4            # top/bottom: more on top, less on bottom (avoid crowding the tab bar)
window-padding-balance = true     # center content within padding
window-decoration = true
macos-titlebar-style = transparent  # tab bar blends into the window
window-save-state = always        # restore previous windows/tabs on relaunch
window-colorspace = display-p3

# ---------- macOS behavior ----------
macos-option-as-alt = true        # Option acts as Alt, handy for tmux etc.

# ---------- Scrolling & mouse ----------
scrollback-limit = 100000
mouse-scroll-multiplier = 3
mouse-hide-while-typing = true

# ---------- Tabs ----------
window-new-tab-position = end     # new tabs open on the right

# ---------- Dim unfocused splits to emphasize focus ----------
unfocused-split-opacity = 0.85
unfocused-split-fill = #e6e9ef    # Latte-style light grey
